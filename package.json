{
  "name": "tikkle",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --mode client",
    "preview": "wrangler pages dev dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply tikkle-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply tikkle-db --remote"
  },
  "dependencies": {
    "drizzle-orm": "0.38.4",
    "hono": "4.12.7",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260305.0",
    "@hono/vite-build": "1.9.3",
    "@hono/vite-dev-server": "0.18.3",
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "3.2.4",
    "autoprefixer": "10.4.27",
    "drizzle-kit": "0.30.6",
    "esbuild": "0.25.12",
    "postcss": "8.5.8",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vite": "6.4.1",
    "vitest": "3.2.4",
    "wrangler": "4.69.0"
  }
}
